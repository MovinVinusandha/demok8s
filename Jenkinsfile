pipeline {
    agent any

    stages {
        stage('Build') {
            steps {
                echo 'Building...'
                sh 'echo "Simulating build process..."'
            }
        }
        stage('Test') {
            steps {
                echo 'Testing...'
                sh 'echo "Simulating test process..."'
            }
        }
        stage('Deploy') {
            steps {
                echo 'Deploying...'
                sh 'echo "Simulating deployment process..."'
            }
        }
    }
}